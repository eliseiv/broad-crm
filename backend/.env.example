# CRM backend — пример переменных окружения (07-deployment.md).
# Скопируйте в .env и заполните секреты. Значения здесь — без реальных секретов.

# Окружение: development | production. На production отключаются /api/docs, /api/openapi.json.
APP_ENV=development

# --- Аутентификация администратора (только в .env, не в БД) ---
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# --- JWT (HS256) ---
# JWT_SECRET: >= 32 случайных байт. Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_EXPIRES_MIN=60
JWT_ALGORITHM=HS256
# TTL setup-токена «первого входа» (type:"pwd_setup", limited-scope; ADR-025). По умолчанию 10 мин.
PWD_SETUP_TOKEN_EXPIRES_MIN=10

# --- Шифрование SSH-паролей (Fernet) ---
# FERNET_KEY: base64, 32 байта. Сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# --- База данных ---
DATABASE_URL=postgresql+asyncpg://crm:pwd@postgres:5432/crm

# --- Prometheus ---
PROMETHEUS_URL=http://prometheus:9090
PROM_QUERY_TIMEOUT_SEC=10
# TTL короткого кэша метрик (сек): гасит наплыв одновременных GET /api/servers.
METRICS_CACHE_TTL_SEC=5

# --- Провижининг / node_exporter ---
EXPORTER_PORT=9100
FILE_SD_DIR=/etc/prometheus/targets
ANSIBLE_TIMEOUT_SEC=300
ANSIBLE_HOST_KEY_CHECKING=false
ANSIBLE_PLAYBOOK_PATH=ansible/install_node_exporter.yml
# Корень для временных private_data_dir ansible-runner (ADR-067 §5). Провижининг обязан
# вызывать tempfile.mkdtemp(dir=<это значение>), а НЕ безадресный mkdtemp() в /tmp: в
# key-режиме здесь на время прогона лежит расшифрованный приватный SSH-ключ (файл 0600
# в каталоге 0700, удаляется в finally). В образе — chown app:app + 0700, в проде поверх
# монтируется ОТДЕЛЬНЫЙ tmpfs (mode: 0o1777) — ключ не касается постоянного диска.
ANSIBLE_PRIVATE_DATA_ROOT=/var/run/crm/ansible
# Потолок размера приватного SSH-ключа в POST /api/servers (байт; 16 КБ = RSA-4096 PEM
# с запасом). Проверяется ДО разбора (анти-DoS); превышение → 422 validation_error,
# поле ssh_private_key.
SSH_KEY_MAX_BYTES=16384
# Публичный IP CRM-сервера (источник скрейпа Prometheus). Плейбук открывает firewall
# на целях для этого IP (TD-017). Пусто = firewall-шаг пропускается.
SCRAPE_SOURCE_IP=

# --- node_exporter (зафиксировано в 02-tech-stack.md; менять только при смене версии) ---
NODE_EXPORTER_VERSION=1.8.2
NODE_EXPORTER_URL=https://github.com/prometheus/node_exporter/releases/download/v1.8.2/node_exporter-1.8.2.linux-amd64.tar.gz
NODE_EXPORTER_SHA256=6809dd0b3ec45fd6e992c19071d6b5253aed3ead7bf0686885a51d85c6643c66

# --- Rate-limit входа (in-memory, TD-005) ---
LOGIN_RATE_LIMIT_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SEC=300

# --- CORS (CSV origin; пусто = выключено, на проде один origin за reverse-proxy) ---
CORS_ALLOW_ORIGINS=

# --- Telegram-нотификатор (опционально; modules/notifier, ADR-009) ---
# Фоновая asyncio-задача внутри backend. Исходящий HTTPS к api.telegram.org.
# Активен ТОЛЬКО если заданы ОБА (TELEGRAM_BOT_TOKEN + TELEGRAM_CHAT_ID); иначе не стартует.
# TELEGRAM_BOT_TOKEN / TELEGRAM_CHAT_ID — СЕКРЕТЫ (только env, не коммитить).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Интервал опроса серверов нотификатором (сек). По умолчанию 60.
NOTIFIER_POLL_INTERVAL_SEC=60
# Окно max_over_time для оценки зоны CPU/RAM/SSD нотификатором (сек, ADR-016).
# Ловит транзиентные всплески между опросами. Нормативно >= NOTIFIER_POLL_INTERVAL_SEC;
# при меньшем значении поднимается до poll_interval с warning. UI-карты не затрагивает.
# По умолчанию 90.
NOTIFIER_METRIC_WINDOW_SEC=90

# --- Монитор AI-ключей (modules/ai-keys, ADR-010) ---
# Фоновая asyncio-задача внутри backend; стартует ВСЕГДА. Исходящий HTTPS к
# api.openai.com и api.anthropic.com (GET /v1/models) — нужен egress в интернет.
# API-ключи вводятся через UI и хранятся зашифрованными в БД (НЕ в env).
# Интервал периодической проверки всех AI-ключей (сек). По умолчанию 900.
AI_KEY_CHECK_INTERVAL_SEC=900
# Таймаут HTTP-запроса к AI-провайдеру при проверке ключа (сек). По умолчанию 10.
AI_PROVIDER_TIMEOUT_SEC=10
# Базовый URL OpenAI API (проверка ключа GET /v1/models).
OPENAI_API_BASE=https://api.openai.com/v1
# Базовый URL Anthropic API (проверка ключа GET /v1/models).
ANTHROPIC_API_BASE=https://api.anthropic.com/v1
# Значение заголовка anthropic-version при запросе к Anthropic API.
ANTHROPIC_API_VERSION=2023-06-01

# --- Монитор доступности прокси (modules/proxies, ADR-019/024) ---
# Интервал периодической проверки всех прокси (сек). По умолчанию 60.
PROXY_CHECK_INTERVAL_SEC=60
# Таймаут проверочного HTTP-запроса через прокси (сек, per-attempt, все фазы httpx). По умолчанию 10.
PROXY_CHECK_TIMEOUT_SEC=10
# Overall-deadline проверки одного прокси (сек, asyncio.wait_for) — анти-зависание; ADR-024. По умолчанию 30.
PROXY_CHECK_DEADLINE_SEC=30
# Эталонный URL проверки связности через прокси (лёгкий 204 No Content).
PROXY_CHECK_URL=https://www.gstatic.com/generate_204
# Grace-порог: непрерывная недоступность прокси (сек) перед 🔴-алертом (30 мин); ADR-027. По умолчанию 1800.
# check_status→error — сразу (реальность в UI), откладывается только уведомление (поля error_since/alert_sent).
PROXY_ALERT_AFTER_SEC=1800

# --- Монитор доступности бэков (modules/backends, ADR-020/024) ---
# Интервал периодической проверки всех бэков (сек). По умолчанию 60.
BACKEND_CHECK_INTERVAL_SEC=60
# Таймаут проверочного запроса GET https://{domain}/health (сек, per-attempt, все фазы httpx). По умолчанию 10.
BACKEND_CHECK_TIMEOUT_SEC=10
# Overall-deadline проверки одного бэка (сек, asyncio.wait_for) — анти-зависание; ADR-024. По умолчанию 30.
BACKEND_CHECK_DEADLINE_SEC=30
# Grace-порог: непрерывная недоступность бэка (сек) перед 🔴-алертом (30 мин); ADR-024. По умолчанию 1800.
BACKEND_ALERT_AFTER_SEC=1800

# --- Модуль «Почты» (read-through-прокси; modules/mail, ADR-012) ---
# Backend проксирует /api/mail/* во внешний postapp.store (исходящий HTTPS),
# подставляя MAIL_API_KEY в заголовок X-API-Key. Без БД (без хранения).
# Базовый URL внешнего почтового сервиса.
MAIL_API_BASE=https://postapp.store
# MAIL_API_KEY — СЕКРЕТ (только env, НЕ коммитить). Здесь — ПУСТОЙ плейсхолдер;
# реальный ключ задать в .env. Пусто → 503 mail_not_configured на /api/mail/*.
MAIL_API_KEY=
#
# --- Таймауты backend → агрегатор: РАЗДЕЛЬНЫЕ бюджеты (ADR-053) ---
# Прежняя норма «единый MAIL_API_TIMEOUT_SEC=10 на ВСЕ пути» ОТМЕНЕНА: на путях,
# где агрегатор идёт на УДАЛЁННЫЙ IMAP/SMTP, 10 с меньше законного времени операции
# → CRM обрывала запрос и отдавала ложный 502 вместо настоящей причины (прод-баг).
# Две категории путей × два бюджета (read одной попытки + overall-deadline вызова).
#
# [Быстрые пути] агрегатор отвечает из своей БД/Redis: delete / sync / oauth-authorize.
# Read-бюджет одной попытки (сек); применяется явным httpx.Timeout ПО ФАЗАМ
# (connect 5 / write 10 / pool 5 — константы кода; read = это значение).
# Границы в config.py: ge=1, le=30. По умолчанию 10.
MAIL_API_TIMEOUT_SEC=10
# Overall-deadline ВСЕГО вызова на быстрых путях (сек, asyncio.wait_for: все попытки
# ретрая + backoff + все фазы). Исчерпание → 502 mail_unavailable.
# Границы в config.py: ge=2, le=60. По умолчанию 30.
MAIL_API_DEADLINE_SEC=30
#
# [Mail-server-пути] агрегатор идёт на УДАЛЁННЫЙ IMAP/SMTP:
#   POST /api/mail/mailboxes/test, POST /api/mail/mailboxes,
#   PATCH /api/mail/mailboxes/{id}, отправка reply.
# Read-бюджет одной попытки (сек). ОБЯЗАН превышать потолок ответа агрегатора
# (60 с — его собственный proxy_read_timeout), иначе CRM обрывает законный долгий
# ответ и отдаёт ложный 502 вместо реального 422 с причиной.
# Границы в config.py: ge=61, le=80. По умолчанию 75.
MAIL_API_MAILSERVER_TIMEOUT_SEC=75
# Overall-deadline ОДНОГО вызова на mail-server-путях (сек, asyncio.wait_for).
# Исчерпание → 504 mail_timeout (НЕ 502: агрегатор доступен, но не успел).
# Границы в config.py: ge=76, le=85 + кросс-полевой model_validator. По умолчанию 85.
MAIL_API_MAILSERVER_DEADLINE_SEC=85
#
# Цепочка бюджетов ОДНОГО вызова обязана строго возрастать наружу:
#   45 (hard-deadline теста у агрегатора) < 60 (nginx агрегатора)
#      < 75 (MAIL_API_MAILSERVER_TIMEOUT_SEC) < 85 (MAIL_API_MAILSERVER_DEADLINE_SEC)
# Бюджет ЗАПРОСА (один HTTP-запрос может содержать НЕСКОЛЬКО вызовов — create делает
# второй, компенсирующее удаление сироты с коротким deadline 15 с, константа кода):
#   85 + 15 + 5 (overhead CRM) = 105 < 120 = proxy_read_timeout nginx CRM
#   (frontend/nginx/default.conf, location /api/; зеркало — NGINX_PROXY_READ_TIMEOUT_SEC).
# При изменении ЛЮБОГО из чисел — пересчитать сумму (ADR-053 §1.2.1, §6);
# машинно это стережёт кросс-полевой model_validator в backend/app/config.py.

# --- Модуль «Документы» (внутренний CRUD + внешний read-only RAG-контур; ADR-060) ---
# DOCUMENTS_API_KEY — СЕКРЕТ (только env, НЕ коммитить; класс MAIL_API_KEY: не в
# БД/логах/ответах/SPA/URL). Статический ключ внешнего read-only контура
# /api/external/documents/* (X-API-Key, constant-time). Здесь — ПУСТОЙ плейсхолдер;
# реальный ключ задать в .env. Пусто → внешний контур выключен
# (/api/external/documents/* → 503 documents_external_not_configured); CRUD работает.
DOCUMENTS_API_KEY=
# DOCUMENTS_MAX_MD_BYTES — НЕ секрет: необязательный тюнинг, потолок Markdown-контента
# документа (байты). Превышение → 422 (document_upload_invalid / validation_error).
# По умолчанию 1048576 (1 МБ).
DOCUMENTS_MAX_MD_BYTES=1048576
# Корень хранения БАЙТОВ изображений документов (ADR-068): точка монтирования named
# volume documents-attachments (смонтирован ТОЛЬКО в backend). Каталоги 0700, файлы 0600;
# путь файла строится только из id вложения и расширения из mime (filename не участвует).
# Каталог создаётся в backend-образе с chown app:app. Бэкапится СОГЛАСОВАННО с pgdata.
DOCUMENTS_ATTACHMENTS_DIR=/var/lib/crm/documents/attachments
# Потолок размера ОДНОГО изображения (байт, 5 МБ). Проверяется по мере чтения потока с
# обрывом; превышение → 422 document_attachment_invalid. Не путать с DOCUMENTS_MAX_MD_BYTES
# (лимит ТЕКСТА документа; data:-картинки в content_md запрещены, ADR-068 §4).
DOCUMENTS_MAX_IMAGE_BYTES=5242880

# --- Модуль «СМС» (Twilio-приём + Telegram-доставка; modules/sms, ADR-030) ---
# Публичные webhook'и наружу под location /api (JWT-exempt, гейт — подпись/секрет):
#   POST /api/sms/webhooks/twilio/sms  и  POST /api/sms/telegram/webhook.
# Доставка операторам — ОТДЕЛЬНЫЙ Telegram-бот (SMS_TELEGRAM_*, НЕ notifier ADR-009).
# Redis НЕ используется (ADR-030 §3; CRM однопроцессный).
# Twilio Account SID (публичный). Пусто → twilio_configured=false (sync → 503 twilio_not_configured).
TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN — СЕКРЕТ (только env, НЕ коммитить): токен Twilio (подпись webhook + Numbers API).
# Не в БД/логах/ответах/SPA/URL. Здесь — ПУСТОЙ плейсхолдер.
TWILIO_AUTH_TOKEN=
# Проверять X-Twilio-Signature на POST /api/sms/webhooks/twilio/sms. Прод — true.
# true без TWILIO_AUTH_TOKEN → 503. Отключать (false) только для локального теста.
VERIFY_TWILIO_SIGNATURE=true
# Публичный базовый URL CRM (внешний HTTPS за nginx) — ЕДИНСТВЕННЫЙ источник URL при
# проверке подписи Twilio (05-security.md#подпись-twilio). ОБЯЗАН совпадать с адресом
# webhook в Twilio-консоли, иначе приём → 401 invalid_twilio_signature.
SMS_PUBLIC_BASE_URL=https://broadappsdev.shop
# SMS_TELEGRAM_BOT_TOKEN — СЕКРЕТ (только env, НЕ коммитить): токен ОТДЕЛЬНОГО SMS-delivery-бота
# (НЕ notifier). Пусто → sms_bot_enabled=false (доставка/retry не стартуют; приём работает и сохраняет).
SMS_TELEGRAM_BOT_TOKEN=
# SMS_TELEGRAM_WEBHOOK_SECRET — СЕКРЕТ (только env, НЕ коммитить): секрет-токен Telegram-webhook
# SMS-бота (X-Telegram-Bot-Api-Secret-Token, constant-time).
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
SMS_TELEGRAM_WEBHOOK_SECRET=
# URL Mini App (кнопка web_app в /start). Домен Mini App регистрируется в @BotFather вручную.
SMS_TELEGRAM_WEBAPP_URL=https://broadappsdev.shop/tg/sms
# Опциональный прокси egress SMS-бота к api.telegram.org (socks5://… / http://…).
# Пусто → прямой egress. Для socks5 нужен httpx[socks]/socksio.
SMS_TELEGRAM_PROXY_URL=
# Интервал фонового retry-монитора доставок SMS (сек). Стартует при sms_bot_enabled. По умолчанию 60.
SMS_DELIVERY_RETRY_INTERVAL_SEC=60
# Потолок попыток доставки одного SMS одному получателю до failed-остановки. По умолчанию 5.
SMS_DELIVERY_MAX_ATTEMPTS=5
