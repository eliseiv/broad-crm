# ============================================================================
# CRM — мониторинг серверов, Этап 1 · пример переменных окружения
# (07-deployment.md#переменные-окружения, 05-security.md#управление-секретами).
#
# Использование:
#   cp .env.example .env        # затем заполнить секреты (см. команды ниже)
#   docker compose --env-file .env -f infra/docker-compose.yml up -d
#
# Файл .env — в .gitignore. РЕАЛЬНЫЕ СЕКРЕТЫ В РЕПОЗИТОРИЙ НЕ КОММИТИТЬ.
#
# Генерация секретов:
#   JWT_SECRET:  python -c "import secrets; print(secrets.token_urlsafe(48))"
#   FERNET_KEY:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   пароли:      python -c "import secrets; print(secrets.token_urlsafe(24))"
# ============================================================================

# --- Окружение ---
# development | production. На production отключаются /api/docs, /api/redoc, /api/openapi.json.
APP_ENV=production

# --- Тег образов (опциональный override; 07-deployment.md#cicd) ---
# По умолчанию `current`. CI (GitHub Actions) IMAGE_TAG НЕ задаёт — собирает
# crm-*:current на сервере через `up -d --build`. Менять вручную нужно лишь для
# отката на ранее собранный тег через legacy infra/scripts/rollback.sh.
IMAGE_TAG=current

# --- Аутентификация администратора (только в .env, не в БД; ADR-008) ---
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# --- JWT (HS256, 05-security.md) ---
JWT_SECRET=
JWT_EXPIRES_MIN=60
JWT_ALGORITHM=HS256

# --- Шифрование SSH-паролей (Fernet, base64 32 байта) ---
FERNET_KEY=

# --- PostgreSQL ---
# ВАЖНО: POSTGRES_USER/PASSWORD/DB должны совпадать с кредами в DATABASE_URL.
POSTGRES_USER=crm
POSTGRES_PASSWORD=change-me
POSTGRES_DB=crm
DATABASE_URL=postgresql+asyncpg://crm:change-me@postgres:5432/crm

# --- Prometheus ---
PROMETHEUS_URL=http://prometheus:9090
PROM_QUERY_TIMEOUT_SEC=10

# --- Провижининг / node_exporter (Ansible) ---
EXPORTER_PORT=9100
FILE_SD_DIR=/etc/prometheus/targets
ANSIBLE_TIMEOUT_SEC=300
ANSIBLE_HOST_KEY_CHECKING=false
# Путь к плейбуку относительно WORKDIR backend-контейнера (/app).
ANSIBLE_PLAYBOOK_PATH=ansible/install_node_exporter.yml
# Публичный IP CRM-сервера для открытия порта 9100 на remote-целях (restricted —
# только этому IP, TD-017). Для self-host оставить ПУСТЫМ (доступ из docker-сети,
# firewall цели не трогается). На этом сервере = 37.27.192.211.
SCRAPE_SOURCE_IP=

# --- node_exporter (зафиксировано в 02-tech-stack.md; менять только при смене версии) ---
NODE_EXPORTER_VERSION=1.8.2
NODE_EXPORTER_URL=https://github.com/prometheus/node_exporter/releases/download/v1.8.2/node_exporter-1.8.2.linux-amd64.tar.gz
NODE_EXPORTER_SHA256=6809dd0b3ec45fd6e992c19071d6b5253aed3ead7bf0686885a51d85c6643c66

# --- Rate-limit входа (in-memory, TD-005) ---
LOGIN_RATE_LIMIT_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SEC=300

# --- CORS (CSV origin; пусто = выключено, на проде один origin за reverse-proxy) ---
CORS_ALLOW_ORIGINS=

# --- Grafana (наружу не публикуется; доступ через proxy /grafana) ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me
# Внешний URL Grafana (sub-path /grafana). Используется и backend'ом для drill-down ссылок.
GRAFANA_BASE_URL=https://localhost/grafana

# --- Reverse-proxy (nginx) / TLS (05-security.md#tls-сертификаты) ---
# Hostname для CN/SAN self-signed серта (Этап 1) и ссылок.
PUBLIC_HOSTNAME=crm.local
# Каталог сертификатов внутри proxy (volume proxy-certs). Для prod положите туда
# реальные fullchain.pem + privkey.pem — они имеют приоритет над автогенерацией.
TLS_CERT_DIR=/etc/nginx/certs

# --- Let's Encrypt (для infra/scripts/issue-cert.sh / renew-cert.sh) ---
# Публичный домен для выпуска валидного серта (нужна DNS A-запись на сервер).
# По умолчанию скрипты берут PUBLIC_HOSTNAME; DOMAIN переопределяет его при необходимости.
DOMAIN=broadappsdev.shop
# Email для уведомлений Let's Encrypt об истечении. Пусто = регистрация без email
# (--register-unsafely-without-email).
LETSENCRYPT_EMAIL=

# --- Frontend build-time (VITE_*, попадают в SPA на этапе сборки proxy-образа) ---
# ORIGIN API БЕЗ /api: frontend buildUrl (src/lib/api.ts) сам добавляет '/api'.
# Для same-origin (SPA и API за одним nginx) — ОСТАВИТЬ ПУСТЫМ, иначе будет /api/api/...
VITE_API_BASE_URL=
# Относительный путь к Grafana за reverse-proxy.
VITE_GRAFANA_URL=/grafana
VITE_POLL_INTERVAL_MS=15000
VITE_STATUS_POLL_INTERVAL_MS=2500
