# ============================================================================
# CRM — мониторинг серверов, Этап 1 · пример переменных окружения
# (07-deployment.md#переменные-окружения, 05-security.md#управление-секретами).
#
# Использование:
#   cp .env.example .env        # затем заполнить секреты (см. команды ниже)
#   docker compose --env-file .env -f infra/docker-compose.yml up -d
#
# Файл .env — в .gitignore. РЕАЛЬНЫЕ СЕКРЕТЫ В РЕПОЗИТОРИЙ НЕ КОММИТИТЬ.
#
# Генерация секретов:
#   JWT_SECRET:  python -c "import secrets; print(secrets.token_urlsafe(48))"
#   FERNET_KEY:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   пароли:      python -c "import secrets; print(secrets.token_urlsafe(24))"
# ============================================================================

# --- Окружение ---
# development | production. На production отключаются /api/docs, /api/redoc, /api/openapi.json.
APP_ENV=production

# --- Тег образов (опциональный override; 07-deployment.md#cicd) ---
# По умолчанию `current`. CI (GitHub Actions) IMAGE_TAG НЕ задаёт — собирает
# crm-*:current на сервере через `up -d --build`. Менять вручную нужно лишь для
# отката на ранее собранный тег через legacy infra/scripts/rollback.sh.
IMAGE_TAG=current

# --- Аутентификация администратора (только в .env, не в БД; ADR-008) ---
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# --- JWT (HS256, 05-security.md) ---
JWT_SECRET=
# TTL access-токена в минутах. По умолчанию 1440 (24 ч; 05-security.md#jwt).
JWT_EXPIRES_MIN=1440
JWT_ALGORITHM=HS256

# --- Шифрование SSH-паролей (Fernet, base64 32 байта) ---
FERNET_KEY=

# --- PostgreSQL ---
# ВАЖНО: POSTGRES_USER/PASSWORD/DB должны совпадать с кредами в DATABASE_URL.
POSTGRES_USER=crm
POSTGRES_PASSWORD=change-me
POSTGRES_DB=crm
DATABASE_URL=postgresql+asyncpg://crm:change-me@postgres:5432/crm

# --- Prometheus ---
PROMETHEUS_URL=http://prometheus:9090
PROM_QUERY_TIMEOUT_SEC=10

# --- Провижининг / node_exporter (Ansible) ---
EXPORTER_PORT=9100
FILE_SD_DIR=/etc/prometheus/targets
ANSIBLE_TIMEOUT_SEC=300
ANSIBLE_HOST_KEY_CHECKING=false
# Путь к плейбуку относительно WORKDIR backend-контейнера (/app).
ANSIBLE_PLAYBOOK_PATH=ansible/install_node_exporter.yml
# Публичный IP CRM-сервера для открытия порта 9100 на remote-целях (restricted —
# только этому IP, TD-017). Для self-host оставить ПУСТЫМ (доступ из docker-сети,
# firewall цели не трогается). На этом сервере = 37.27.192.211.
SCRAPE_SOURCE_IP=

# --- node_exporter (зафиксировано в 02-tech-stack.md; менять только при смене версии) ---
NODE_EXPORTER_VERSION=1.8.2
NODE_EXPORTER_URL=https://github.com/prometheus/node_exporter/releases/download/v1.8.2/node_exporter-1.8.2.linux-amd64.tar.gz
NODE_EXPORTER_SHA256=6809dd0b3ec45fd6e992c19071d6b5253aed3ead7bf0686885a51d85c6643c66

# --- Rate-limit входа (in-memory, TD-005) ---
LOGIN_RATE_LIMIT_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SEC=300

# --- CORS (CSV origin; пусто = выключено, на проде один origin за reverse-proxy) ---
CORS_ALLOW_ORIGINS=

# --- Telegram-нотификатор (опционально; modules/notifier, ADR-009) ---
# Фоновая asyncio-задача внутри backend (НЕ отдельный сервис). Исходящий HTTPS
# к api.telegram.org (backend должен иметь egress в интернет).
# Активен ТОЛЬКО если заданы ОБА: TELEGRAM_BOT_TOKEN и TELEGRAM_CHAT_ID.
# Пусто (хотя бы одно) → нотификатор не стартует, backend работает штатно.
# TELEGRAM_BOT_TOKEN / TELEGRAM_CHAT_ID — СЕКРЕТЫ (только env, в репозиторий не коммитить).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Интервал опроса серверов нотификатором (сек). По умолчанию 60.
NOTIFIER_POLL_INTERVAL_SEC=60
# Окно max_over_time для оценки зоны CPU/RAM/SSD нотификатором (сек, ADR-016).
# Ловит транзиентные всплески между опросами. Нормативно >= NOTIFIER_POLL_INTERVAL_SEC;
# при меньшем значении поднимается до poll_interval с warning. UI-карты не затрагивает.
# По умолчанию 90.
NOTIFIER_METRIC_WINDOW_SEC=90

# --- Монитор AI-ключей (modules/ai-keys, ADR-010) ---
# Фоновая asyncio-задача внутри backend (НЕ отдельный сервис); стартует ВСЕГДА.
# Исходящий HTTPS к api.openai.com и api.anthropic.com (GET /v1/models) —
# backend должен иметь egress в интернет. Сами API-ключи вводятся через UI и
# хранятся зашифрованными в БД (НЕ в env). Telegram-алерты гейтятся TELEGRAM_*.
# Интервал периодической проверки всех AI-ключей (сек). По умолчанию 900.
AI_KEY_CHECK_INTERVAL_SEC=900
# Таймаут HTTP-запроса к AI-провайдеру при проверке ключа (сек). По умолчанию 10.
AI_PROVIDER_TIMEOUT_SEC=10
# Базовый URL OpenAI API (проверка ключа GET /v1/models).
OPENAI_API_BASE=https://api.openai.com/v1
# Базовый URL Anthropic API (проверка ключа GET /v1/models).
ANTHROPIC_API_BASE=https://api.anthropic.com/v1
# Значение заголовка anthropic-version при запросе к Anthropic API.
ANTHROPIC_API_VERSION=2023-06-01

# --- Монитор доступности прокси (modules/proxies, ADR-019) ---
# Фоновая asyncio-задача внутри backend (НЕ отдельный сервис); стартует ВСЕГДА.
# Проверяет каждый прокси, выполняя GET эталонного PROXY_CHECK_URL ЧЕРЕЗ сам прокси.
# Требует исходящий сетевой доступ backend к хостам прокси и к эталонному URL.
# Пароли прокси вводятся через UI и хранятся зашифрованными в БД (НЕ в env).
# Telegram-алерты гейтятся TELEGRAM_*. Для socks5-прокси нужен httpx[socks]/socksio.
# Интервал периодической проверки всех прокси (сек). По умолчанию 60.
PROXY_CHECK_INTERVAL_SEC=60
# Таймаут проверочного HTTP-запроса через прокси (сек, per-attempt, все фазы httpx). По умолчанию 10.
PROXY_CHECK_TIMEOUT_SEC=10
# Overall-deadline проверки одного прокси (сек, asyncio.wait_for) — анти-зависание; ADR-024. По умолчанию 30.
PROXY_CHECK_DEADLINE_SEC=30
# Эталонный URL для проверки связности через прокси (лёгкий 204 No Content).
PROXY_CHECK_URL=https://www.gstatic.com/generate_204
# Grace-порог: непрерывная недоступность прокси (сек) перед 🔴-алертом (30 мин); ADR-027. По умолчанию 1800.
# check_status→error — сразу (реальность в UI), откладывается только уведомление (поля error_since/alert_sent).
PROXY_ALERT_AFTER_SEC=1800

# --- Монитор healthcheck бэков (modules/backends, ADR-020) ---
# Фоновая asyncio-задача внутри backend (НЕ отдельный сервис); стартует ВСЕГДА.
# Проверяет каждый бэк запросом GET https://{domain}/health (путь /health и схема
# https:// фиксированы; строго 2xx = работает). Требует исходящий HTTPS egress
# backend к доменам бэков. Секрета у сущности нет (Код/Название/Домен — публичны).
# Telegram-алерты гейтятся TELEGRAM_*.
# Интервал периодической проверки всех бэков (сек). По умолчанию 60.
BACKEND_CHECK_INTERVAL_SEC=60
# Таймаут проверочного запроса GET /health (сек, per-attempt, все фазы httpx). По умолчанию 10.
BACKEND_CHECK_TIMEOUT_SEC=10
# Overall-deadline проверки одного бэка (сек, asyncio.wait_for) — анти-зависание; ADR-024. По умолчанию 30.
BACKEND_CHECK_DEADLINE_SEC=30
# Grace-порог: непрерывная недоступность бэка (сек) перед 🔴-алертом (30 мин); ADR-024. По умолчанию 1800.
BACKEND_ALERT_AFTER_SEC=1800

# --- Модуль «Почты» (read-through-прокси; modules/mail, ADR-012) ---
# Backend синхронно проксирует /api/mail/* во внешний сервис postapp.store,
# подставляя MAIL_API_KEY в заголовок X-API-Key. Требует исходящий HTTPS egress
# backend → postapp.store. Внешний rate-limit 120 запросов/мин на IP (не опрашивать
# агрессивно). БД под почту нет (без хранения). Образцы клиента с секретом в
# заголовке — app/infra/ai_provider.py, app/infra/prometheus.py.
# Базовый URL внешнего почтового сервиса.
MAIL_API_BASE=https://postapp.store
# MAIL_API_KEY — СЕКРЕТ (только env, в репозиторий НЕ коммитить). Реальный ключ
# задаётся администратором в .env (gitignored); здесь — ПУСТОЙ плейсхолдер.
# Пусто → почта не настроена (mail_enabled=false, /api/mail/* → 503 mail_not_configured).
MAIL_API_KEY=
# Таймаут HTTP-запроса backend → postapp.store (сек). По умолчанию 10.
MAIL_API_TIMEOUT_SEC=10

# --- Модуль «СМС» (Twilio-приём + Telegram-доставка; modules/sms, ADR-030) ---
# Приём входящих SMS от Twilio (webhook с проверкой подписи) + доставка операторам
# через ОТДЕЛЬНЫЙ Telegram-бот (SMS_TELEGRAM_*, НЕ notifier ADR-009). Публичные
# webhook'и наружу под location /api (JWT-exempt, гейт — подпись/секрет):
#   POST /api/sms/webhooks/twilio/sms  и  POST /api/sms/telegram/webhook.
# Redis НЕ используется (ADR-030 §3; CRM однопроцессный).
#
# Twilio Account SID (публичный идентификатор). Пусто → twilio_configured=false
# (POST /api/sms/numbers/sync → 503 twilio_not_configured).
TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN — СЕКРЕТ (только env, НЕ коммитить): токен Twilio для валидации
# подписи webhook и Numbers API. Не в БД/логах/ответах/SPA/URL. Здесь — ПУСТОЙ плейсхолдер.
TWILIO_AUTH_TOKEN=
# Проверять X-Twilio-Signature на POST /api/sms/webhooks/twilio/sms. Прод — true.
# true без TWILIO_AUTH_TOKEN → 503. Отключать (false) только для локального теста.
VERIFY_TWILIO_SIGNATURE=true
# Публичный базовый URL CRM (внешний HTTPS-адрес за nginx) — ЕДИНСТВЕННЫЙ источник URL
# при проверке подписи Twilio (05-security.md#подпись-twilio). ОБЯЗАН совпадать с адресом
# webhook в Twilio-консоли, иначе приём → 401 invalid_twilio_signature.
SMS_PUBLIC_BASE_URL=https://broadappsdev.shop
# SMS_TELEGRAM_BOT_TOKEN — СЕКРЕТ (только env, НЕ коммитить): токен ОТДЕЛЬНОГО
# SMS-delivery-бота (НЕ notifier). Пусто → sms_bot_enabled=false (доставка/retry-монитор
# не стартуют; приём SMS работает и сохраняет без доставки).
SMS_TELEGRAM_BOT_TOKEN=
# SMS_TELEGRAM_WEBHOOK_SECRET — СЕКРЕТ (только env, НЕ коммитить): секрет-токен
# Telegram-webhook SMS-бота (X-Telegram-Bot-Api-Secret-Token, constant-time).
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
SMS_TELEGRAM_WEBHOOK_SECRET=
# URL Mini App (кнопка web_app в приветствии /start). Домен Mini App регистрируется
# в @BotFather вручную.
SMS_TELEGRAM_WEBAPP_URL=https://broadappsdev.shop/sms
# Опциональный прокси для egress SMS-бота к api.telegram.org (socks5://… / http://…).
# Пусто → прямой egress. Для socks5 нужен httpx[socks]/socksio.
SMS_TELEGRAM_PROXY_URL=
# Интервал фонового retry-монитора доставок SMS (сек). Стартует при sms_bot_enabled. По умолчанию 60.
SMS_DELIVERY_RETRY_INTERVAL_SEC=60
# Потолок попыток доставки одного SMS одному получателю до failed-остановки. По умолчанию 5.
SMS_DELIVERY_MAX_ATTEMPTS=5

# --- Grafana (наружу не публикуется; доступ через proxy /grafana) ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me
# Внешний root URL Grafana (sub-path /grafana, GF_SERVER_ROOT_URL) выводится в
# docker-compose.yml из PUBLIC_HOSTNAME (см. ниже) — отдельная переменная не нужна.

# --- Reverse-proxy (nginx) / TLS (05-security.md#tls-сертификаты) ---
# Hostname для CN/SAN self-signed серта (Этап 1) и ссылок.
PUBLIC_HOSTNAME=crm.local
# Каталог сертификатов внутри proxy (volume proxy-certs). Для prod положите туда
# реальные fullchain.pem + privkey.pem — они имеют приоритет над автогенерацией.
TLS_CERT_DIR=/etc/nginx/certs

# --- Let's Encrypt (для infra/scripts/issue-cert.sh / renew-cert.sh) ---
# Публичный домен для выпуска валидного серта (нужна DNS A-запись на сервер).
# По умолчанию скрипты берут PUBLIC_HOSTNAME; DOMAIN переопределяет его при необходимости.
DOMAIN=broadappsdev.shop
# Email для уведомлений Let's Encrypt об истечении. Пусто = регистрация без email
# (--register-unsafely-without-email).
LETSENCRYPT_EMAIL=

# --- Frontend build-time (VITE_*, попадают в SPA на этапе сборки proxy-образа) ---
# ORIGIN API БЕЗ /api: frontend buildUrl (src/lib/api.ts) сам добавляет '/api'.
# Для same-origin (SPA и API за одним nginx) — ОСТАВИТЬ ПУСТЫМ, иначе будет /api/api/...
VITE_API_BASE_URL=
VITE_POLL_INTERVAL_MS=15000
VITE_STATUS_POLL_INTERVAL_MS=2500
