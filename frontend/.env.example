# Базовый origin/префикс backend API БЕЗ суффикса /api.
# Клиент (buildUrl) сам добавляет /api к каждому пути → НЕ указывай здесь /api (иначе будет /api/api/...).
# Для same-origin (SPA и API за одним reverse-proxy) — оставить ПУСТЫМ.
# Пример внешнего origin: https://crm.example.com  → запрос пойдёт на https://crm.example.com/api/...
# Локальная разработка: оставить пустым — Vite проксирует /api на VITE_DEV_API_PROXY.
VITE_API_BASE_URL=

# Интервал routine-polling списка серверов GET /api/servers (мс). Норматив docs: 15000.
VITE_POLL_INTERVAL_MS=15000

# Интервал опроса GET /api/servers/{id}/status во время провижининга (мс). Только pending/installing.
VITE_STATUS_POLL_INTERVAL_MS=2500

# Только для dev: куда Vite проксирует /api (см. vite.config.ts).
VITE_DEV_API_PROXY=http://localhost:8000
